    "decompose:smoke": "node scripts/decompose-smoke.mjs",
    "test:decompose": "node scripts/decompose.mjs --self-test",
    "probe:frontier": "node scripts/refusal-frontier.mjs",
    "test:frontier": "node scripts/refusal-frontier.mjs --self-test",
    "cli-hunt": "node scripts/cli-hunt.mjs",
    "test:cli-hunt": "node scripts/cli-hunt.mjs --self-test",
    "swarm": "node scripts/cli-swarm.mjs",
    "test:swarm": "node scripts/cli-swarm.mjs --self-test",
    "test:no-fitting": "node scripts/test-no-fitting.mjs",
    "test:autodetect": "node scripts/test-autodetect.mjs",
    "test:arsenal-tools": "node scripts/test-arsenal-tools.mjs",
    "lessons": "node scripts/lessons.mjs",
    "test:lessons": "node scripts/lessons.mjs --self-test",
    "test:no-self-fitting": "node scripts/test-no-self-fitting.mjs",
    "test:no-phantom-tools": "vitest run src/__tests__/no-phantom-tools.test.ts",
    "test:spine-live": "vitest run src/__tests__/spine-live.test.ts",
    "smoke": "node scripts/smoke.mjs",
    "smoke:live": "node scripts/smoke.mjs --live",
    "capability": "node scripts/capability-smoke.mjs",
    "gauntlet": "node scripts/capability-smoke.mjs --gauntlet",
    "test:gate": "npm run build --silent && node scripts/test-gate.mjs"
  },
  "bin": {
    "tempest": "./dist/cli.js",
    "t3mp3st": "./dist/cli.js"
  },
  "keywords": [
    "penetration-testing",
    "security",
    "red-team",
    "multi-agent",
    "ai",
    "llm"
  ],
  "author": "t3mp3st contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elder-plinius/T3MP3ST.git"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1081.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^15.0.0",
    "conf": "^15.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "eventemitter3": "^5.0.4",
    "express": "^4.22.2",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "helmet": "^8.2.0",
    "inquirer": "^14.0.2",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/figlet": "^1.7.0",
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "qs": "^6.11.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
