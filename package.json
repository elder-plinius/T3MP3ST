  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "setup": "tsx src/setup.ts",
    "setup:api": "bash scripts/setup-api.sh",
    "doctor": "node scripts/doctor.mjs",
    "verify-claims": "node scripts/verify-claims.mjs",
    "export:clean": "bash scripts/clean-export.sh",
    "disclose": "node scripts/disclosure-gen.mjs",
    "test:disclose": "node scripts/test-disclosure-gen.mjs",
    "verify-finding": "node scripts/verify-finding.mjs",
    "test:verify": "node scripts/test-verify-finding.mjs",
    "test:fallback": "node scripts/test-model-fallback.mjs",
    "server": "tsx src/server.ts",
    "server:prod": "node dist/server.js",
    "field:drill": "node scripts/field-drill.mjs",
    "exploit:smoke": "node scripts/exploit-chain-smoke.mjs",
    "arsenal:smoke": "node scripts/arsenal-smoke.mjs",
    "arsenal:doctor": "node scripts/arsenal-doctor.mjs",
    "prompt:audit": "node scripts/prompt-audit.mjs",
    "cve:bench": "node scripts/cve-hunt-bench.mjs",
    "cve:bench:live": "node scripts/cve-hunt-bench.mjs --live",
    "cve:bench:adversarial": "node scripts/cve-hunt-bench.mjs --adversarial",
    "cloud:bench": "node scripts/cloud-misconfig-bench.mjs",
    "cloud:bench:live": "node scripts/cloud-misconfig-bench.mjs --live",
    "mobile:bench": "node scripts/mobile-static-bench.mjs",
    "binary:bench": "node scripts/binary-vuln-bench.mjs",
    "keys": "bash scripts/keys.sh",
    "keys:list": "bash scripts/keys.sh list",
    "obsidian": "node scripts/obsidian-sync.mjs",
    "obsidian:watch": "node scripts/obsidian-sync.mjs --watch",
    "obsidian:inbox": "node scripts/obsidian-inbox.mjs",
    "obsidian:bench": "node scripts/obsidian-sync.mjs --bench-only",
    "obsidivm": "node scripts/obsidivm-bridge.mjs",
