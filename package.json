    "mcp:prod": "node dist/mcp-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test:playbooks": "node scripts/test-playbook-routing.mjs",
