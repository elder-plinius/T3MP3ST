# T3MP3ST — environment template
# Copy to .env and fill in the values you need.  NEVER commit your real .env.
#
#   cp .env.example .env
#
# At least one LLM provider key is required (OpenRouter is the default backbone).
# All other variables are optional unless noted.

# ── Web access (HTTPS via Nginx) ──────────────────────────────────────────────

# Host port the HTTPS proxy is exposed on. Nginx inside the container always
# listens on :8443; this maps the HOST port to it.
# Change to 443 to use the standard HTTPS port (may need Docker run as root).
TEMPEST_HTTPS_PORT=8443

# Admin password for the login page. If left blank, a 32-character random
# password is generated on every container startup and printed to the logs.
# Run `make logs` or `docker compose logs` to see it.
# Set a fixed value here if you need a stable password across restarts.
TEMPEST_PASSWORD=

# ── LLM providers (set at least one) ─────────────────────────────────────────

OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY=
TOGETHER_API_KEY=
HUGGINGFACE_TOKEN=
REPLICATE_API_TOKEN=
VENICE_API_KEY=

# ── LLM routing ───────────────────────────────────────────────────────────────

# Which provider to use. Options: openrouter | anthropic | openai | groq | together
LLM_PROVIDER=openrouter

# Model string for the chosen provider.
# openrouter example:  anthropic/claude-opus-4-8
LLM_MODEL=

# Fallback model if the primary call fails (optional).
TEMPEST_MODEL_FALLBACK=

# Per-LLM-call timeout in milliseconds (default: 120000).
TEMPEST_GENERAL_TIMEOUT_MS=

# ── T3MP3ST server ────────────────────────────────────────────────────────────

T3MP3ST_PORT=3333
T3MP3ST_HOST=0.0.0.0

# Bearer token required on all /api/* routes. Leave blank to disable auth.
T3MP3ST_API_TOKEN=

# Additional CORS origin allowed beyond localhost (e.g. https://your-ops-panel.example.com).
T3MP3ST_CORS_ORIGIN=

# Restrict the deep-scanner to a specific directory tree.
T3MP3ST_SCAN_ROOT=

# Comma-separated webhook URLs pre-registered as catch-all listeners at startup.
T3MP3ST_WEBHOOK_URL=

# State / mission persistence directory (default: /data/missions inside container).
T3MP3ST_STATE_DIR=

# ── GitHub ────────────────────────────────────────────────────────────────────

# Required for xbow-bench challenge fetch and gh operations.
GITHUB_TOKEN=

# ── Local agent connectors ────────────────────────────────────────────────────

# Set to 0 to disable the --yolo flag when spawning the Hermes local agent.
HERMES_YOLO=0

# ── Cloud / Binary sidecar services ──────────────────────────────────────────
# Bearer tokens for the cloud and binary analysis sidecar containers.
# Auto-generated by scripts/generate-certs.sh — run it once before docker compose build.
# Do NOT set these by hand; the script generates cryptographically random values.
CLOUD_SIDECAR_TOKEN=
BINARY_SIDECAR_TOKEN=

# ── HuggingFace ───────────────────────────────────────────────────────────────

# Access token required for gated models (Llama 3.x, Mistral, etc.).
HF_TOKEN=

# Where HuggingFace caches downloaded weights.
# The /data/models volume must be mounted for this to persist across restarts.
HF_HOME=/data/models/hf-cache

